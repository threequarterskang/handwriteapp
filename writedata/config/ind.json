{
  "type": "field_driven_sample_plan",
  "description": "IND.mod",

  "source_db": "placeholder.db",
  "$comment": "lookup_table: field_rule",
  "key_column": "英文名字",

  "inspect_result_value": "符合要求",
  "sample_strategy": "gb2828_IND",
  "fail_result_num": "0",

  "rules": [
    {
      "stage": "base",
      "when": "gt({8}, 1)",
      "then": {
        "{17}": "'符合要求'",
		    "{28}": "'92K'",
		
        "{53}": "'电感量(mH)A'",
        "{65}": "'B'",
        "{77}": "'C'",
        "{89}": "'阻抗电压(%)A'",
        "{101}": "'B'",
        "{113}": "'C'",

        "{47}": "if_not_empty({9}, '尺寸(mm)W', '')",
        "{59}": "if_not_empty({10}, 'D', '')",
        "{71}": "if_not_empty({13}, 'A', '')",
        "{83}": "if_not_empty({14}, 'B', '')",
        "{95}": "if_not_empty({12}, 'H线', '')",
        "{107}": "if_not_empty({11}, 'H铁', '')",

        "{18}": "random_range_from_percent_if_exists({9})",
        "{19}": "random_range_from_percent_if_exists({10})",
        "{20}": "random_range_from_percent_if_exists({11})",
        "{21}": "random_range_from_percent_if_exists({12})",
        "{22}": "random_range_from_col({13})",
        "{23}": "random_range_from_col({14})",

        "{24}": "random_pair_from_fixed_set(1.2, 1.3, 1.4, 1.5, 'mA')",
        "{25}": "random_pair_from_range_exclusive(360, 380, 'MΩ')",

        "{26}": "random_pair_from_percent_range_with_prefix({15}, 'A、B、C ')",
        "{27}": "random_pair_from_dash_range_with_prefix({16}, 'A、B、C ')"
      }
    },
    {
      "stage": "series",
      "when": "gt({8}, 1)",
      "then": {
        "{48}_{52}": "fill_range_by_count({8}, {18}, 48, 52, 0)",
        "{60}_{64}": "fill_range_by_count({8}, {19}, 60, 64, 0)",
        "{72}_{76}": "fill_range_by_count({8}, {22}, 72, 76, 0)",
        "{84}_{88}": "fill_range_by_count({8}, {23}, 84, 88, 0)",

        "{96}_{100}": "fill_range_by_count_if({8}, {21}, 96, 100, {12}, 0)",
        "{108}_{112}": "fill_range_by_count_if({8}, {20}, 108, 112, {11}, 0)",

        "{54}_{58}": "fill_range_by_count({8}, {26}, 54, 58, 1)",
        "{66}_{70}": "fill_range_by_count({8}, {26}, 66, 70, 1)",
        "{78}_{82}": "fill_range_by_count({8}, {26}, 78, 82, 1)",

        "{90}_{94}": "fill_range_by_count({8}, {27}, 90, 94, 1)",
        "{102}_{106}": "fill_range_by_count({8}, {27}, 102, 106, 1)",
        "{114}_{118}": "fill_range_by_count({8}, {27}, 114, 118, 1)"        
    
      }
    },
    {
      "stage": "base",
      "when": "eq({8}, 1)",
      "then": {
        "{17}": "'符合要求'",
		    "{28}": "'92K'",
		
        "{18}": "extract_left_of_tilde_percentage({9})",
        "{19}": "extract_left_of_tilde_percentage({10})",
        "{20}": "extract_left_of_tilde_percentage({11})",
        "{21}": "extract_left_of_tilde_percentage({12})",
        "{22}": "extract_left_of_tilde_nopercentage({13})",
        "{23}": "extract_left_of_tilde_nopercentage({14})",

        "{24}": "electrical_strengthvalue_from_fixed_set_and_add_suffix(1.2, 1.3, 1.4, 1.5,'mA')",
        "{25}": "insulation_resistancevalue_from_fixed_set_and_add_suffix(360, 380, 'MΩ')",
        "{26}": "inductancevalue_and_add_suffix({15}, 'mH')",
        "{27}": "impendance_voltagevalue_and_add_suffix({16}, '%')"
      }
    },

    {
      "when": "lt({8}, 1)",
      "then": { }
    }
  ]
}